# Google AI Studio API key (free tier) - get from https://aistudio.google.com/
GOOGLE_API_KEY=your-gemini-api-key

# GCP Project
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery dataset(s) to query
BQ_DATASET=your-dataset

# Optional: path to service account key JSON
# If not set, uses Application Default Credentials (ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
